{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "docs",
  "functions": {
    "api/*.js": {
      "runtime": "edge"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "headers": {
        "Access-Control-Allow-Origin": "https://olderdyad.github.io",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "*"
      },
      "dest": "/api/$1"
    }
  ]
}






