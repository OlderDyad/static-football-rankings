{
    "version": 2,
    "buildCommand": null,
    "outputDirectory": "src",
    "functions": {
      "api/*.js": {
        "runtime": "edge",
        "memory": 256
      }
    },
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/api/$1"
      },
      {
        "handle": "filesystem"
      },
      {
        "src": "/(.*)",
        "dest": "/index.html"
      }
    ],
    "env": {
      "VERCEL_POSTGRES_URL": "@postgres-url"
    }
  }